# Copy to `.env` and adjust. Restart `npm run dev` after changes.
# All values are absolute URLs (no Vite dev proxy).

# --- Gateway (port 7000): one host for every service ---
# VITE_PROFILE_API_URL=http://localhost:7000
# VITE_COGNITIVE_API_URL=http://localhost:7000/cognitive
# VITE_THERAPY_API_URL=http://localhost:7000/therapy
# VITE_EMOTIONAL_API_URL=http://localhost:7000/emotional/api

# --- Direct to each service (no gateway) ---
VITE_PROFILE_API_URL=http://localhost:7001
VITE_COGNITIVE_API_URL=http://localhost:7002
VITE_THERAPY_API_URL=http://localhost:7005
VITE_EMOTIONAL_API_URL=http://localhost:7003/api
